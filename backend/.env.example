# Порт сервера
PORT=3000

# Підключення до бази даних (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nailbook?schema=public"

# Секрет для генерації JWT токенів
JWT_SECRET="your_super_secret_jwt_key_here"

# Telegram Bot
# Згенеруйте через @BotFather в Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCDefghIJKLmnopQRSTuvwxYZ"
TELEGRAM_BOT_USERNAME="nailbook_bot"

# Google Calendar OAuth 2.0
# Згенеруйте в Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# Expo Push Notifications
# Якщо ви використовуєте EAS Credentials, тут можуть бути специфічні ключі 
# (для MVP зазвичай вистачає локального налаштування)
EXPO_ACCESS_TOKEN=""
